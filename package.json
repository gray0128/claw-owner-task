{
  "name": "claw-owner-task",
  "version": "1.9.1",
  "type": "module",
  "description": "A simple task manager for personal use and OpenCLaw agent",
  "main": "src/worker/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create claw-owner-task-db",
    "db:migrate:local": "wrangler d1 migrations apply claw-owner-task-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply claw-owner-task-db --remote",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/run_api_tests.js"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240222.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.69.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
